{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMcbCeA4hk1YUM4lVSCUAQX"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","metadata":{"id":"ecc091a2"},"source":["## Learning Vector Quantization (LVQ) Implementation from Machine Learning Mastery\n","\n","This section contains the implementation of the LVQ algorithm, largely adapted from the tutorial by Jason Brownlee on Machine Learning Mastery:\n","[https://machinelearningmastery.com/implement-learning-vector-quantization-scratch-python/](https://machinelearningmastery.com/implement-learning-vector-quantization-scratch-python/)"]},{"cell_type":"code","metadata":{"id":"b32db2f8","executionInfo":{"status":"ok","timestamp":1777383826367,"user_tz":-330,"elapsed":54,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["from random import seed\n","from random import randrange\n","from random import random\n","from csv import reader\n","from math import sqrt"],"execution_count":44,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"3ee743e1"},"source":["### Load a CSV file"]},{"cell_type":"code","metadata":{"id":"5f8fe518","executionInfo":{"status":"ok","timestamp":1777383826369,"user_tz":-330,"elapsed":51,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def load_csv(filename):\n","    dataset = list()\n","    with open(filename, 'r') as file:\n","        csv_reader = reader(file)\n","        for row in csv_reader:\n","            if not row:\n","                continue\n","            dataset.append(row)\n","    return dataset"],"execution_count":45,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"176bd662"},"source":["### Convert string column to float"]},{"cell_type":"code","metadata":{"id":"fe78a6b2","executionInfo":{"status":"ok","timestamp":1777383826371,"user_tz":-330,"elapsed":49,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def str_column_to_float(dataset, column):\n","    for row in dataset:\n","        row[column] = float(row[column].strip())"],"execution_count":46,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"5ccd5fa2"},"source":["### Convert string column to integer"]},{"cell_type":"code","metadata":{"id":"0a00be58","executionInfo":{"status":"ok","timestamp":1777383826374,"user_tz":-330,"elapsed":45,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def str_column_to_int(dataset, column):\n","    class_values = [row[column] for row in dataset]\n","    unique = set(class_values)\n","    lookup = dict()\n","    for i, value in enumerate(unique):\n","        lookup[value] = i\n","    for row in dataset:\n","        row[column] = lookup[row[column]]\n","    return lookup"],"execution_count":47,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"7179edd4"},"source":["### Find the min and max values for each column"]},{"cell_type":"code","metadata":{"id":"11440cfb","executionInfo":{"status":"ok","timestamp":1777383826379,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def dataset_minmax(dataset):\n","    minmax = list()\n","    for i in range(len(dataset[0])):\n","        col_values = [row[i] for row in dataset]\n","        value_min = min(col_values)\n","        value_max = max(col_values)\n","        minmax.append([value_min, value_max])\n","    return minmax"],"execution_count":48,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"fb8b1330"},"source":["### Rescale dataset columns to the range [0-1]"]},{"cell_type":"code","metadata":{"id":"386ed60e","executionInfo":{"status":"ok","timestamp":1777383826419,"user_tz":-330,"elapsed":37,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def normalize_dataset(dataset, minmax):\n","    for row in dataset:\n","        for i in range(len(row)):\n","            if minmax[i][1] - minmax[i][0] != 0:\n","                row[i] = (row[i] - minmax[i][0]) / (minmax[i][1] - minmax[i][0])\n","            else:\n","                row[i] = 0.0 # Handle cases where min and max are the same (constant column)"],"execution_count":49,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"64c09ce7"},"source":["### Split a dataset into k folds"]},{"cell_type":"code","metadata":{"id":"034fd308","executionInfo":{"status":"ok","timestamp":1777383826427,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def cross_validation_split(dataset, n_folds):\n","    dataset_split = list()\n","    dataset_copy = list(dataset)\n","    fold_size = int(len(dataset) / n_folds)\n","    for i in range(n_folds):\n","        fold = list()\n","        while len(fold) < fold_size:\n","            index = randrange(len(dataset_copy))\n","            fold.append(dataset_copy.pop(index))\n","        dataset_split.append(fold)\n","    return dataset_split"],"execution_count":50,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"864d417a"},"source":["### Calculate accuracy percentage"]},{"cell_type":"code","metadata":{"id":"cf43589c","executionInfo":{"status":"ok","timestamp":1777383826433,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def accuracy_metric(actual, predicted):\n","    correct = 0\n","    for i in range(len(actual)):\n","        if actual[i] == predicted[i]:\n","            correct += 1\n","    return correct / float(len(actual)) * 100.0"],"execution_count":51,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"7c5bf4d7"},"source":["### Evaluate an algorithm using a cross validation split"]},{"cell_type":"code","metadata":{"id":"3e3c93f0","executionInfo":{"status":"ok","timestamp":1777383826440,"user_tz":-330,"elapsed":4,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def evaluate_algorithm(dataset, algorithm, n_folds, *args):\n","    folds = cross_validation_split(dataset, n_folds)\n","    scores = list()\n","    for fold in folds:\n","        train_set = list(folds)\n","        train_set.remove(fold)\n","        train_set = sum(train_set, [])\n","        test_set = list()\n","        for row in fold:\n","            row_copy = list(row)\n","            test_set.append(row_copy)\n","            row_copy[-1] = None # 'None' for the class label in test set\n","        predicted = algorithm(train_set, test_set, *args)\n","        actual = [row[-1] for row in fold]\n","        accuracy = accuracy_metric(actual, predicted)\n","        scores.append(accuracy)\n","    return scores"],"execution_count":52,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"f50ecf1c"},"source":["### Calculate the Euclidean distance between two vectors"]},{"cell_type":"code","metadata":{"id":"686a3f36","executionInfo":{"status":"ok","timestamp":1777383826475,"user_tz":-330,"elapsed":32,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def euclidean_distance(row1, row2):\n","    distance = 0.0\n","    for i in range(len(row1) - 1):\n","        distance += (row1[i] - row2[i])**2\n","    return sqrt(distance)"],"execution_count":53,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"af86d159"},"source":["### Locate the best matching unit"]},{"cell_type":"code","metadata":{"id":"fec3a5bd","executionInfo":{"status":"ok","timestamp":1777383826482,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def get_best_matching_unit(codebooks, test_row):\n","    distances = list()\n","    for codebook in codebooks:\n","        dist = euclidean_distance(codebook, test_row)\n","        distances.append((codebook, dist))\n","    distances.sort(key=lambda tup: tup[1])\n","    return distances[0][0]"],"execution_count":54,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"fa698087"},"source":["### Generate a random codebook vector"]},{"cell_type":"code","metadata":{"id":"c221f442","executionInfo":{"status":"ok","timestamp":1777383826487,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def random_codebook(train):\n","    n_records = len(train)\n","    n_features = len(train[0])\n","    codebook = [train[randrange(n_records)][i] for i in range(n_features)]\n","    return codebook"],"execution_count":55,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"795a7e65"},"source":["### Train a number of codebook vectors"]},{"cell_type":"code","metadata":{"id":"695190ce","executionInfo":{"status":"ok","timestamp":1777383826493,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def train_codebooks(train, n_codebooks, lrate, epochs):\n","    codebooks = [random_codebook(train) for i in range(n_codebooks)]\n","    for epoch in range(epochs):\n","        rate = lrate * (1.0-(epoch/float(epochs)))\n","        sum_error = 0.0\n","        for row in train:\n","            bmu = get_best_matching_unit(codebooks, row)\n","            for i in range(len(row)-1):\n","                error = row[i] - bmu[i]\n","                sum_error += error**2\n","                if bmu[-1] == row[-1]:\n","                    bmu[i] += rate * error\n","                else:\n","                    bmu[i] -= rate * error\n","        print('>epoch=%d, lrate=%.3f, error=%.3f' % (epoch, rate, sum_error))\n","    return codebooks"],"execution_count":56,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"dfc40e04"},"source":["### Make a prediction with a list of codebook vectors"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Hw4eD9SGTPcv","executionInfo":{"status":"ok","timestamp":1777383826516,"user_tz":-330,"elapsed":20,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}},"outputId":"8ab333e8-7acf-4fe0-8a00-c067d5ff2f53"},"source":["# Test the training function\n","seed(1)\n","dataset = [[2.7810836,2.550537003,0],\n","\t[1.465489372,2.362125076,0],\n","\t[3.396561688,4.400293529,0],\n","\t[1.38807019,1.850220317,0],\n","\t[3.06407232,3.005305973,0],\n","\t[7.627531214,2.759262235,1],\n","\t[5.332441248,2.088626775,1],\n","\t[6.922596716,1.77106367,1],\n","\t[8.675418651,-0.242068655,1],\n","\t[7.673756466,3.508563011,1]]\n","learn_rate = 0.3\n","n_epochs = 10\n","n_codebooks = 2\n","codebooks = train_codebooks(dataset, n_codebooks, learn_rate, n_epochs)\n","print('Codebooks: %s' % codebooks)"],"execution_count":57,"outputs":[{"output_type":"stream","name":"stdout","text":[">epoch=0, lrate=0.300, error=43.270\n",">epoch=1, lrate=0.270, error=30.403\n",">epoch=2, lrate=0.240, error=27.146\n",">epoch=3, lrate=0.210, error=26.301\n",">epoch=4, lrate=0.180, error=25.537\n",">epoch=5, lrate=0.150, error=24.789\n",">epoch=6, lrate=0.120, error=24.058\n",">epoch=7, lrate=0.090, error=23.346\n",">epoch=8, lrate=0.060, error=22.654\n",">epoch=9, lrate=0.030, error=21.982\n","Codebooks: [[2.432316086217663, 2.839821664184211, 0], [7.319592257892681, 1.97013382654341, 1]]\n"]}]},{"cell_type":"code","metadata":{"id":"9b7d557b","executionInfo":{"status":"ok","timestamp":1777383826522,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def predict(codebooks, test_row):\n","    bmu = get_best_matching_unit(codebooks, test_row)\n","    return bmu[-1]"],"execution_count":58,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"2502d3dc"},"source":["### Learning Vector Quantization Algorithm"]},{"cell_type":"code","metadata":{"id":"dbd28101","executionInfo":{"status":"ok","timestamp":1777383826528,"user_tz":-330,"elapsed":3,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}}},"source":["def learning_vector_quantization(train, test, n_codebooks, lrate, epochs):\n","    codebooks = train_codebooks(train, n_codebooks, lrate, epochs)\n","    predictions = list()\n","    for row in test:\n","        prediction = predict(codebooks, row)\n","        predictions.append(prediction)\n","    return predictions"],"execution_count":59,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"e3a5cbcc"},"source":["### Test the LVQ on the Ionosphere Dataset"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"28b5ffa8","executionInfo":{"status":"ok","timestamp":1777383833692,"user_tz":-330,"elapsed":7161,"user":{"displayName":"CS Vishal Rout","userId":"06986873296388645372"}},"outputId":"6660daf1-36bf-4792-c5fa-5916952c06f0"},"source":["# Test LVQ on Ionosphere dataset\n","seed(1)\n","\n","# download the data\n","import urllib.request\n","url = 'https://raw.githubusercontent.com/jbrownlee/Datasets/master/ionosphere.csv'\n","urllib.request.urlretrieve(url, 'ionosphere_article.csv')\n","\n","filename = 'ionosphere_article.csv'\n","dataset = load_csv(filename)\n","\n","for i in range(len(dataset[0]) - 1):\n","    str_column_to_float(dataset, i)\n","# convert class column to integers\n","str_column_to_int(dataset, len(dataset[0]) - 1)\n","# normalize input variables\n","minmax = dataset_minmax(dataset)\n","normalize_dataset(dataset, minmax)\n","\n","# evaluate algorithm\n","n_folds = 5\n","lrate = 0.3\n","n_epochs = 50\n","n_codebooks = 20\n","scores = evaluate_algorithm(dataset, learning_vector_quantization, n_folds, n_codebooks, lrate, n_epochs)\n","print(f'Scores: {scores}')\n","print(f'Mean Accuracy: {sum(scores)/float(len(scores)):.3f}%')"],"execution_count":60,"outputs":[{"output_type":"stream","name":"stdout","text":[">epoch=0, lrate=0.300, error=536.112\n",">epoch=1, lrate=0.294, error=498.638\n",">epoch=2, lrate=0.288, error=469.325\n",">epoch=3, lrate=0.282, error=470.935\n",">epoch=4, lrate=0.276, error=459.923\n",">epoch=5, lrate=0.270, error=452.736\n",">epoch=6, lrate=0.264, error=449.384\n",">epoch=7, lrate=0.2